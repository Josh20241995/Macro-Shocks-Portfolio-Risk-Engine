<Window x:Class="MacroShockDashboard.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Macro Shock Risk Engine — Operational Dashboard"
        Height="900" Width="1440"
        MinHeight="720" MinWidth="1200"
        Background="#0f1117"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Base styles -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#1a1d27"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="6"/>
        </Style>
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8b9db0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="LetterSpacing" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="ValueLargeStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#e8ecf0"/>
            <Setter Property="FontSize" Value="36"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8b9db0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#e8ecf0"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="DividerStyle" TargetType="Rectangle">
            <Setter Property="Fill" Value="#2a2d3a"/>
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="0,8"/>
        </Style>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Status bar -->
            <RowDefinition Height="Auto"/>   <!-- Weekend gap banner -->
            <RowDefinition Height="2*"/>     <!-- Main content -->
            <RowDefinition Height="1.2*"/>   <!-- Bottom panels -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════
             ROW 0 — Top Status Bar
             ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#1a1d27" CornerRadius="8" Padding="16,10" Margin="6,6,6,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo / Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="■" Foreground="#3b82f6" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="MACRO SHOCK RISK ENGINE" Foreground="#e8ecf0"
                               FontSize="13" FontWeight="Bold" VerticalAlignment="Center" LetterSpacing="2"/>
                </StackPanel>

                <!-- Event info -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="24,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="EVENT:" Style="{StaticResource LabelStyle}" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding EventTitle}" Foreground="#e8ecf0" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Text=" · " Foreground="#8b9db0" FontSize="12"/>
                    <TextBlock Text="{Binding EventInstitution}" Foreground="#8b9db0" FontSize="12"/>
                    <TextBlock Text=" · " Foreground="#8b9db0" FontSize="12"/>
                    <TextBlock Text="{Binding EventType}" Foreground="#8b9db0" FontSize="12"/>
                </StackPanel>

                <!-- Loading indicator -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,16,0"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="UPDATING..." Foreground="#3b82f6" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Last updated -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Updated " Style="{StaticResource LabelStyle}"/>
                    <TextBlock Text="{Binding LastUpdatedDisplay}" Foreground="#6b7a8d" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════
             ROW 1 — Weekend Gap Corridor Banner (conditional)
             ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Margin="6,3" Padding="12,8" CornerRadius="6"
                Background="{Binding WeekendGapColor, Mode=OneWay}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding WeekendGapLabel}"
                           Foreground="White" FontSize="12" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding MondayGapDisplay}"
                           Foreground="White" FontSize="12" FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════
             ROW 2 — Main Content (4 columns)
             ═══════════════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>  <!-- Composite score -->
                <ColumnDefinition Width="1.3*"/>  <!-- Sub-scores -->
                <ColumnDefinition Width="1.5*"/>  <!-- Scenario tree -->
                <ColumnDefinition Width="1.1*"/>  <!-- Portfolio guidance -->
            </Grid.ColumnDefinitions>

            <!-- ── COL 0: Composite Risk Score ───────────────── -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="COMPOSITE RISK SCORE" Style="{StaticResource SectionHeaderStyle}"/>

                    <!-- Score gauge -->
                    <Grid Margin="0,8,0,16">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding CompositeScore, StringFormat='{}{0:F1}'}"
                                       HorizontalAlignment="Center"
                                       Style="{StaticResource ValueLargeStyle}"
                                       FontSize="56"/>
                            <TextBlock Text="/ 100" Foreground="#8b9db0" FontSize="16"
                                       HorizontalAlignment="Center" Margin="0,-4,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Score bar -->
                    <Grid Height="12" Margin="0,0,0,12">
                        <Rectangle Fill="#2a2d3a" RadiusX="6" RadiusY="6"/>
                        <Rectangle Fill="{Binding SeverityColor}"
                                   RadiusX="6" RadiusY="6"
                                   HorizontalAlignment="Left">
                            <Rectangle.Width>
                                <MultiBinding>
                                    <Binding Path="CompositeScore"/>
                                    <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth"/>
                                </MultiBinding>
                            </Rectangle.Width>
                        </Rectangle>
                    </Grid>

                    <!-- Severity badge -->
                    <Border Background="{Binding SeverityColor}" CornerRadius="4" Padding="10,4" HorizontalAlignment="Center" Margin="0,0,0,12">
                        <TextBlock Text="{Binding SeverityLabel}" Foreground="White"
                                   FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </Border>

                    <Rectangle Style="{StaticResource DividerStyle}"/>

                    <!-- Key metrics -->
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="REGIME" Style="{StaticResource SectionHeaderStyle}"/>
                            <TextBlock Text="{Binding Regime}" Foreground="#e8ecf0" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="ACTION" Style="{StaticResource SectionHeaderStyle}"/>
                            <TextBlock Text="{Binding ActionLevel}" Foreground="#e8ecf0" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>

                    <Rectangle Style="{StaticResource DividerStyle}"/>

                    <!-- Summary text -->
                    <TextBlock Text="{Binding SummaryText}"
                               Foreground="#8b9db0" FontSize="11"
                               TextWrapping="Wrap" LineHeight="16"/>

                    <!-- Error state -->
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#ef4444" FontSize="11"
                               TextWrapping="Wrap"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource NotEmptyToVis}}"/>
                </StackPanel>
            </Border>

            <!-- ── COL 1: Sub-Score Heatmap ───────────────────── -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="RISK DECOMPOSITION"
                               Style="{StaticResource SectionHeaderStyle}"/>
                    <ItemsControl ItemsSource="{Binding SubScores}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                   Foreground="#c5cdd6" FontSize="11" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding ScoreDisplay}"
                                                   Foreground="#e8ecf0" FontSize="11" FontWeight="Bold"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                    <!-- Score bar -->
                                    <Grid Grid.Row="1" Margin="0,2,0,0">
                                        <Rectangle Fill="#2a2d3a" RadiusX="3" RadiusY="3"/>
                                        <Rectangle Fill="{Binding BarColor}" RadiusX="3" RadiusY="3"
                                                   HorizontalAlignment="Left" Width="{Binding BarWidth}"/>
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>

            <!-- ── COL 2: Scenario Tree ───────────────────────── -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="SCENARIO TREE" Style="{StaticResource SectionHeaderStyle}"/>

                    <!-- Expected values summary -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="EXPECTED EQUITY" Style="{StaticResource SectionHeaderStyle}"/>
                            <TextBlock Text="{Binding ExpectedEquityDisplay}"
                                       Foreground="#e8ecf0" FontSize="20" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="TAIL LOSS (5th Pct)" Style="{StaticResource SectionHeaderStyle}"/>
                            <TextBlock Text="{Binding TailLossDisplay}"
                                       Foreground="#ef4444" FontSize="20" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>

                    <Rectangle DockPanel.Dock="Top" Style="{StaticResource DividerStyle}"/>

                    <!-- Scenario table header -->
                    <Grid DockPanel.Dock="Top" Margin="0,4,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="52"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="SCENARIO" Style="{StaticResource SectionHeaderStyle}" Margin="0"/>
                        <TextBlock Grid.Column="1" Text="PROB" Style="{StaticResource SectionHeaderStyle}" HorizontalAlignment="Right" Margin="0"/>
                        <TextBlock Grid.Column="2" Text="EQUITY" Style="{StaticResource SectionHeaderStyle}" HorizontalAlignment="Right" Margin="0"/>
                        <TextBlock Grid.Column="3" Text="10Y" Style="{StaticResource SectionHeaderStyle}" HorizontalAlignment="Right" Margin="0"/>
                        <TextBlock Grid.Column="4" Text="VIX Δ" Style="{StaticResource SectionHeaderStyle}" HorizontalAlignment="Right" Margin="0"/>
                    </Grid>

                    <!-- Scenario rows -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Scenarios}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding RowBackground}" CornerRadius="3" Margin="0,1">
                                        <Grid Margin="4,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="52"/>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="50"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                       Foreground="#c5cdd6" FontSize="11"/>
                                            <TextBlock Grid.Column="1" Text="{Binding ProbabilityDisplay}"
                                                       Foreground="#e8ecf0" FontSize="11" FontWeight="SemiBold"
                                                       HorizontalAlignment="Right"/>
                                            <TextBlock Grid.Column="2" Text="{Binding EquityImpactDisplay}"
                                                       FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Right">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsTail}" Value="True">
                                                                <Setter Property="Foreground" Value="#ef4444"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsTail}" Value="False">
                                                                <Setter Property="Foreground" Value="#e8ecf0"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Grid.Column="3" Text="{Binding Yield10YDisplay}"
                                                       Foreground="#8b9db0" FontSize="11" HorizontalAlignment="Right"/>
                                            <TextBlock Grid.Column="4" Text="{Binding VixChangeDisplay}"
                                                       Foreground="#8b9db0" FontSize="11" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- ── COL 3: Portfolio Guidance ──────────────────── -->
            <Border Grid.Column="3" Style="{StaticResource CardStyle}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="PORTFOLIO GUIDANCE"
                               Style="{StaticResource SectionHeaderStyle}"/>

                    <!-- Asset class guidance snippets -->
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Text="EQUITY" Style="{StaticResource SectionHeaderStyle}" Margin="0,4,0,2"/>
                        <TextBlock Text="{Binding EquityGuidance}" Foreground="#c5cdd6"
                                   FontSize="11" TextWrapping="Wrap" LineHeight="16"/>

                        <Rectangle Style="{StaticResource DividerStyle}"/>

                        <TextBlock Text="RATES" Style="{StaticResource SectionHeaderStyle}" Margin="0,4,0,2"/>
                        <TextBlock Text="{Binding RatesGuidance}" Foreground="#c5cdd6"
                                   FontSize="11" TextWrapping="Wrap" LineHeight="16"/>

                        <Rectangle Style="{StaticResource DividerStyle}"/>

                        <TextBlock Text="CREDIT" Style="{StaticResource SectionHeaderStyle}" Margin="0,4,0,2"/>
                        <TextBlock Text="{Binding CreditGuidance}" Foreground="#c5cdd6"
                                   FontSize="11" TextWrapping="Wrap" LineHeight="16"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════
             ROW 3 — Bottom Panels (Hedges + Alerts)
             ═══════════════════════════════════════════════════ -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.8*"/>  <!-- Hedge recommendations -->
                <ColumnDefinition Width="1*"/>    <!-- Alerts -->
            </Grid.ColumnDefinitions>

            <!-- ── Hedge Recommendations ──────────────────────── -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="HEDGE RECOMMENDATIONS"
                               Style="{StaticResource SectionHeaderStyle}"/>
                    <TextBlock DockPanel.Dock="Top"
                               Text="All recommendations require explicit PM / Risk Officer authorization before execution."
                               Foreground="#4b5563" FontSize="10" Margin="0,0,0,8" FontStyle="Italic"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding HedgeRecommendations}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#21242f" CornerRadius="4" Margin="0,3" Padding="10,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Asset class + action -->
                                            <StackPanel Grid.Column="0">
                                                <Border Background="{Binding UrgencyColor}" CornerRadius="3" Padding="4,2" HorizontalAlignment="Left" Margin="0,0,0,4">
                                                    <TextBlock Text="{Binding Urgency}" Foreground="White" FontSize="9" FontWeight="Bold"/>
                                                </Border>
                                                <TextBlock Text="{Binding AssetClass}" Foreground="#8b9db0" FontSize="10"/>
                                                <TextBlock Text="{Binding Action}" Foreground="#e8ecf0" FontSize="11" FontWeight="Bold"/>
                                            </StackPanel>

                                            <!-- Instrument + sizing -->
                                            <StackPanel Grid.Column="1" Margin="8,0">
                                                <TextBlock Text="{Binding Instrument}" Foreground="#c5cdd6"
                                                           FontSize="11" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Sizing}" Foreground="#8b9db0"
                                                           FontSize="10" Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <!-- Approval flag -->
                                            <Border Grid.Column="2" Background="#1f2937" CornerRadius="3" Padding="6,3" VerticalAlignment="Top">
                                                <TextBlock Text="PM REQUIRED" Foreground="#f59e0b"
                                                           FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- ── Alerts Panel ────────────────────────────────── -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Text="ALERTS" Style="{StaticResource SectionHeaderStyle}" VerticalAlignment="Center"/>
                        <Border HorizontalAlignment="Right" CornerRadius="10" Padding="8,2"
                                Visibility="{Binding HasCriticalAlerts, Converter={StaticResource BoolToVis}}">
                            <Border.Background>
                                <SolidColorBrush Color="#dc2626"/>
                            </Border.Background>
                            <TextBlock Text="{Binding CriticalAlertCount, StringFormat='{}{0} CRITICAL'}"
                                       Foreground="White" FontSize="10" FontWeight="Bold"/>
                        </Border>
                    </Grid>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Alerts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,3" Padding="10,8" CornerRadius="4" Background="#21242f">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="{Binding LevelColor}"
                                                    Width="3" Margin="0,0,8,0" CornerRadius="2"/>
                                            <StackPanel Grid.Column="1">
                                                <Grid>
                                                    <TextBlock Text="{Binding Title}" Foreground="#e8ecf0"
                                                               FontSize="11" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding TimestampDisplay}"
                                                               Foreground="#4b5563" FontSize="10"
                                                               HorizontalAlignment="Right"/>
                                                </Grid>
                                                <TextBlock Text="{Binding Level}" Foreground="{Binding LevelColor}"
                                                           FontSize="9" FontWeight="Bold" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
